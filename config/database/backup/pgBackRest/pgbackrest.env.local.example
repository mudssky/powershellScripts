# 复制为 pgbackrest.env.local 后使用；真实文件已被 .gitignore 忽略。
# 本文件供 Postgres-Toolkit.ps1 pgbackrest --env-file 读取。

# pgBackRest 基础配置。
PGBR_CONFIG=./pgbackrest.conf.local
PGBR_STANZA=lobechat
PGBR_BACKUP_TYPE=full

# 远程物理备份：执行机通过 Tailscale/SSH 访问 macmini。
# 可以把 macmini 替换成 Tailscale IP，例如 100.x.y.z。
PGBR_PG1_HOST=macmini
PGBR_PG1_HOST_TYPE=ssh
PGBR_PG1_HOST_USER=postgres
PGBR_PG1_PATH=/var/lib/postgresql/data
PGBR_REPO1_PATH=/var/backups/pgbackrest/lobechat

# 逻辑备份：Postgres-Toolkit.ps1 backup 使用 PG* 变量通过 TCP 访问 lobechat。
PGHOST=macmini
PGPORT=5432
PGUSER=postgres
PGDATABASE=lobechat

# 密码建议二选一：
# 1. 使用 PGPASSFILE，文件权限 chmod 600，内容类似：macmini:5432:lobechat:postgres:REPLACE_ME
# 2. 临时 export PGPASSWORD=REPLACE_ME，再执行脚本
# PGPASSFILE=./pgpass.local
# PGPASSWORD=REPLACE_ME
