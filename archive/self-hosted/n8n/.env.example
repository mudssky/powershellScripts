# n8n self-hosted 模板环境变量示例
# 使用前建议复制为 `.env` 后按本机实际情况调整：
#   cp self-hosted/n8n/.env.example self-hosted/n8n/.env

# =====================
# ===== 容器基础 =====
# =====================

# n8n 官方 Docker 镜像。长期使用建议替换 latest 为明确版本号。
N8N_IMAGE=docker.n8n.io/n8nio/n8n:latest

# 容器重启策略。
N8N_RESTART_POLICY=unless-stopped

# n8n 数据目录。macOS 长期部署建议使用：
# /Volumes/Data/docker_data/n8n
N8N_DATA_PATH=./data/n8n

# n8n 工作流和定时任务使用的时区。
N8N_TIMEZONE=Asia/Shanghai

# 启用 task runner，匹配 n8n 官方 Docker 启动建议。
N8N_RUNNERS_ENABLED=true

# 固定凭据加密密钥。正式使用前必须替换为长随机字符串，并妥善备份。
N8N_ENCRYPTION_KEY=change-me-to-a-long-random-string

# =====================
# ===== 访问入口 =====
# =====================

# HTTP 对外端口。
N8N_HTTP_PORT=5678

# 浏览器访问 n8n 的主机名、协议与 webhook 根地址。
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_SECURE_COOKIE=false
N8N_WEBHOOK_URL=http://localhost:5678/

# =======================
# ===== 外部 PostgreSQL =====
# =======================

# 复用宿主机共享 PostgreSQL，和 Forgejo 使用同一个 PostgreSQL 实例。
N8N_DB_HOST=host.docker.internal
N8N_DB_PORT=5432
N8N_DB_NAME=n8n
N8N_DB_USER=postgres
N8N_DB_PASSWORD=12345678
N8N_DB_SCHEMA=public
