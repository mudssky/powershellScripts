{
  "strategy": {
    "mode": "fallback",
    "on_status_codes": [408, 429, 500, 502, 503, 504]
  },
  "request_timeout": 15000,
  "retry": {
    "attempts": 2,
    "on_status_codes": [408, 429, 500, 502, 503, 504],
    "use_retry_after_headers": true
  },
  "targets": [
    {
      "provider": "openai",
      "api_key": "sk-your-newapi-key",
      "custom_host": "https://newapi-primary.example.com/v1",
      "override_params": {
        "model": "qwen-plus",
        "temperature": 0.3,
        "max_tokens": 4096
      }
    },
    {
      "provider": "openai",
      "api_key": "sk-your-newapi-key",
      "custom_host": "https://newapi-primary.example.com/v1",
      "override_params": {
        "model": "qwen-flash",
        "temperature": 0.3,
        "max_tokens": 4096
      }
    }
  ]
}
