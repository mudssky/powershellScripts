# Forgejo self-hosted 模板环境变量示例
# 使用前建议复制为 `.env` 后按本机实际情况调整：
#   cp self-hosted/forgejo/.env.example self-hosted/forgejo/.env

# =====================
# ===== 容器基础 =====
# =====================

# Forgejo 官方 rootless 镜像。需要固定版本时替换 tag。
FORGEJO_IMAGE=codeberg.org/forgejo/forgejo:15-rootless

# 容器重启策略。
FORGEJO_RESTART_POLICY=unless-stopped

# rootless 容器运行用户，需要能读写 ./data/forgejo。
FORGEJO_USER_UID=1000
FORGEJO_USER_GID=1000

# Forgejo 数据目录。macOS 可参考 start-container.ps1 的默认数据盘：
# /Volumes/Data/docker_data/forgejo
FORGEJO_DATA_PATH=./data/forgejo

# =====================
# ===== 访问入口 =====
# =====================

# HTTP 对外端口，沿用旧 Gitea 的 30001。
FORGEJO_HTTP_PORT=30001

# SSH 对外端口，不占用宿主机 22。
FORGEJO_SSH_PORT=2222

# 浏览器访问 Forgejo 的完整地址，反向代理部署时改为外部 URL。
FORGEJO_ROOT_URL=http://localhost:30001/

# Web 域名与 SSH clone 域名。局域网或反向代理访问时改成真实域名。
FORGEJO_DOMAIN=localhost
FORGEJO_SSH_DOMAIN=localhost

# =======================
# ===== 外部 PostgreSQL =====
# =======================

# 复用宿主机共享 PostgreSQL，参考 LobeHub external 模式。
FORGEJO_DB_HOST=host.docker.internal:5432
FORGEJO_DB_NAME=forgejo
FORGEJO_DB_USER=postgres
FORGEJO_DB_PASSWORD=12345678
FORGEJO_DB_SSL_MODE=disable

# =====================
# ===== 日志配置 =====
# =====================

FORGEJO_LOG_LEVEL=info
