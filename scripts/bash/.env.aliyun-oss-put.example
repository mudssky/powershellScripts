# Example configuration for scripts/bash/aliyun-oss-put.sh.
# Copy this file to .env.aliyun-oss-put for shared defaults.
# Put machine-local or sensitive overrides in .env.aliyun-oss-put.local.

ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
# ALIYUN_SECURITY_TOKEN=your-sts-token
ALIYUN_OSS_BUCKET=examplebucket
ALIYUN_OSS_REGION=cn-hangzhou
ALIYUN_OSS_HOST=examplebucket.oss-cn-hangzhou.aliyuncs.com
# ALIYUN_OSS_CONTENT_TYPE=application/octet-stream
