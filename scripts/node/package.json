{
  "name": "node-script",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:fast": "vitest run",
    "test:watch": "vitest",
    "build": "rimraf dist && rspack build && tsx generate-bin.ts",
    "build:dev": "rimraf dist && cross-env MINIFY=false rspack build && tsx generate-bin.ts",
    "build:standalone": "rimraf dist && rspack build && cross-env COPY_JS=true tsx generate-bin.ts",
    "dev": "tsx src/hello.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:fast": "tsgo --noEmit",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "biome:fixAll": "pnpm run check:fix",
    "qa": "pnpm run typecheck:fast && pnpm run check && pnpm run test:fast"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@rspack/cli": "^2.0.6",
    "@rspack/core": "^2.0.6",
    "@types/inquirer": "^9.0.9",
    "@types/json-diff": "^1.0.3",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^25.9.4",
    "cross-env": "^10.1.0",
    "execa": "^9.6.1",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "private": "true",
  "dependencies": {
    "commander": "^15.0.0",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "inquirer": "^14.0.2",
    "json-diff": "^1.0.6",
    "minimatch": "^10.2.5"
  }
}
