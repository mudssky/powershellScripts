{
  "hooks": {
    "enabled": true,
    "events": {
      "SessionStart": [
        {
          "matcher": "startup|clear|compact",
          "hooks": [
            {
              "type": "command",
              "command": "python3 \"${ZCODE_PROJECT_DIR}/.zcode/hooks/session-start.py\"",
              "timeout": 30
            }
          ]
        }
      ],
      "UserPromptSubmit": [
        {
          "hooks": [
            {
              "type": "command",
              "command": "python3 \"${ZCODE_PROJECT_DIR}/.zcode/hooks/inject-workflow-state.py\"",
              "timeout": 15
            }
          ]
        }
      ],
      "PreToolUse": [
        {
          "matcher": "Agent|Task",
          "hooks": [
            {
              "type": "command",
              "command": "python3 \"${ZCODE_PROJECT_DIR}/.zcode/hooks/inject-subagent-context.py\"",
              "timeout": 30
            }
          ]
        }
      ]
    }
  }
}
