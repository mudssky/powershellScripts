{
  "schemaVersion": 1,
  "entries": [
    {
      "id": "batch-1-config-frontend-deprecated",
      "batch": 1,
      "source": "config/frontend/deprecated/**",
      "archive": "archive/config/frontend/deprecated/**",
      "reason": "旧 Biome v1 与 Prettier 配置已退出当前工具链",
      "replacement": {
        "kind": "path",
        "target": "biome.json",
        "text": "使用根 biome.json"
      }
    },
    {
      "id": "batch-1-config-software-pixpin-deprecated",
      "batch": 1,
      "source": "config/software/pixpin/deprecated/**",
      "archive": "archive/config/software/pixpin/deprecated/**",
      "reason": "日期化旧配置快照不再作为当前真源",
      "replacement": {
        "kind": "path",
        "target": "config/software/pixpin/PixPin.pixconf",
        "text": "使用当前 PixPin 配置"
      }
    },
    {
      "id": "batch-1-config-vscode-back",
      "batch": 1,
      "source": "config/vscode/back/**",
      "archive": "archive/config/vscode/back/**",
      "reason": "历史 VS Code Vim 配置备份无活动引用",
      "replacement": {
        "kind": "paths",
        "items": [
          {
            "target": "config/vscode/settings",
            "text": "VS Code settings"
          },
          {
            "target": "config/vscode/neovim",
            "text": "VS Code Neovim 配置"
          }
        ]
      }
    },
    {
      "id": "batch-1-deprecated",
      "batch": 1,
      "source": "deprecated/**",
      "archive": "archive/deprecated/**",
      "reason": "旧脚本已失效、被替代或不再维护",
      "replacement": {
        "kind": "path",
        "target": "scripts/pwsh/media/concatflv.ps1",
        "text": "concatflv.ps1 使用当前脚本；其余文件仅供历史参考"
      }
    },
    {
      "id": "batch-1-macos-archive",
      "batch": 1,
      "source": "macos/archive/**",
      "archive": "archive/macos/archive/**",
      "reason": "LaunchAgent 合盖轮询方案无法可靠阻止残留进程",
      "replacement": {
        "kind": "paths",
        "items": [
          {
            "target": "macos/hammerspoon",
            "text": "Hammerspoon 配置"
          },
          {
            "target": "macos/09deployHammerspoon.zsh",
            "text": "Hammerspoon 部署脚本"
          }
        ]
      }
    },
    {
      "id": "batch-1-profile-deprecated",
      "batch": 1,
      "source": "profile/deprecated/**",
      "archive": "archive/profile/deprecated/**",
      "reason": "旧 Linux Profile 已被模块化 Profile 替代",
      "replacement": {
        "kind": "path",
        "target": "profile/profile.ps1",
        "text": "使用当前模块化 Profile"
      }
    },
    {
      "id": "batch-2-vercel-project",
      "batch": 2,
      "source": ".vercel/project.json",
      "archive": "archive/.vercel/project.json",
      "reason": "本仓已停止使用 Vercel 部署",
      "replacement": {
        "kind": "note",
        "text": "仅保留旧项目标识，无活动替代入口"
      }
    },
    {
      "id": "batch-2-ipynb-renamelegal",
      "batch": 2,
      "source": "ipynb/renameLegal.ipynb",
      "archive": "archive/ipynb/renameLegal.ipynb",
      "reason": "Notebook 已有受维护的 PowerShell 脚本替代",
      "replacement": {
        "kind": "path",
        "target": "scripts/pwsh/filesystem/renameLegal.ps1",
        "text": "使用受维护的 PowerShell 脚本"
      }
    },
    {
      "id": "batch-3-promptx",
      "batch": 3,
      "source": ".promptx",
      "archive": "archive/.promptx",
      "reason": "根 PromptX 项目角色与资源已退出活动维护",
      "replacement": {
        "kind": "note",
        "text": "仅供历史参考；活动 PromptX MCP 配置位于 ai/mcp"
      }
    },
    {
      "id": "batch-3-trae",
      "batch": 3,
      "source": ".trae",
      "archive": "archive/.trae",
      "reason": "本仓库已退出 Trae 项目配置维护",
      "replacement": {
        "kind": "path",
        "target": ".agents/skills",
        "text": "使用共享 agent skills 与现有 Claude/Codex 配置"
      }
    },
    {
      "id": "batch-3-openspec",
      "batch": 3,
      "source": "openspec",
      "archive": "archive/openspec",
      "reason": "OpenSpec 工作流已退出本仓库活动维护",
      "replacement": {
        "kind": "path",
        "target": ".trellis",
        "text": "使用 Trellis 任务、规范与工作流"
      }
    },
    {
      "id": "batch-4-linux-archlinux",
      "batch": 4,
      "source": "linux/archlinux",
      "archive": "archive/linux/archlinux",
      "reason": "Arch 旧脚本的有效能力已吸收到统一 Linux 流水线与新的显式 yay 入口",
      "replacement": {
        "kind": "path",
        "target": "linux/INSTALL.md",
        "text": "使用统一 Linux 安装指南"
      }
    },
    {
      "id": "batch-4-linux-cloundsever",
      "batch": 4,
      "source": "linux/cloundsever",
      "archive": "archive/linux/cloundsever",
      "reason": "旧云服务器服务清单无活动调用，服务启动由受维护的通用容器入口提供",
      "replacement": {
        "kind": "path",
        "target": "scripts/pwsh/devops/start-container.ps1",
        "text": "使用通用容器启动管理脚本"
      }
    },
    {
      "id": "batch-4-linux-ubuntu",
      "batch": 4,
      "source": "linux/ubuntu",
      "archive": "archive/linux/ubuntu",
      "reason": "旧 Ubuntu 安装脚本已由统一 Linux 00-99 流水线替代",
      "replacement": {
        "kind": "path",
        "target": "linux/INSTALL.md",
        "text": "使用统一 Linux 安装指南"
      }
    },
    {
      "id": "batch-4-linux-wsl2",
      "batch": 4,
      "source": "linux/wsl2",
      "archive": "archive/linux/wsl2",
      "reason": "旧 WSL2 安装与服务脚本已由统一 Linux 客体流水线和 Windows WSL 宿主配置替代",
      "replacement": {
        "kind": "path",
        "target": "linux/INSTALL.md",
        "text": "使用统一 Linux 与 WSL 安装指南"
      }
    }
  ]
}
