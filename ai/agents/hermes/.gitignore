# Hermes 本地密钥与运行环境
.env
.env.*
!.env.example
.venv/
venv/

# Hermes 用户配置含有模型路由、个人提示词与可能内联的密钥，只保存在本机。
config.yaml
SOUL.md

# Hermes 本地认证、状态与数据库
auth.json
auth.lock
state.db*
kanban.db*
gateway_state.json
channel_directory.json
models_dev_cache.json
gateway.pid
gateway.lock
.update_check

# Hermes 运行日志、缓存与临时目录
logs/
audio_cache/
image_cache/
tmp/
temp/

# Hermes 会话、记忆、沙箱和配对状态通常含有个人上下文
sessions/
memories/
sandboxes/
pairing/
pastes/

# Hermes 自动生成的备份与锁文件
*.bak.*
*.lock
cron/
hooks/
cron/output/

# Hermes 官方 bundled skills 会由安装/更新流程同步，避免把整套本地技能产物提交进仓库。
skills/

# 上游源码目录建议独立管理，避免整包误提交到当前仓库
hermes-agent/
