{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .trae/hooks/session-start.py",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .trae/hooks/inject-workflow-state.py",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
